#!/usr/bin/env python3
# =============================================================================
#  verify_prop_7_6_radiative_quartics.py
#
#  Electromagnetic Sphere monograph -- machine verification of the algebra
#  behind
#     Prop. 7.5  (prop:octant-spectrum) -- octant mass sum rules            [EXACT]
#     Prop. 7.6  (prop:quartics)        -- radiative quartics B, C          [DERIVED]
#     Prop. 7.7  (prop:no-cubic)        -- absence of the chiral cubic      [OPEN]
#
#  What is RIGOROUSLY established here (Section A):
#    (i)   Tr Phi^n = sum_{eps in {+/-1}^3} (eps . phi)^n  for the explicit
#          8x8 condensate Phi = sum_i phi_i omega^i, omega^i = e_i e_{i+3}.
#    (ii)  Tr Phi^2 = 8 sum phi_i^2 ,
#          Tr Phi^4 = 8 sum phi_i^4 + 48 sum_{i<j} phi_i^2 phi_j^2 .
#    (iii) Tr Phi^4 and (Tr Phi^2)^2 are LINEARLY INDEPENDENT quartic
#          invariants (coefficient determinant = -2048 != 0).  Hence the
#          fermion loop, whose mass^4 sum is the octant quartic = Tr Phi^4,
#          generates B and contributes ZERO to C.  [Prop. 7.6(1)]
#    (iv)  Octant power sums are even under every phi_i -> -phi_i, while the
#          chiral cubic Tr(Phi^3 I) ∝ phi1 phi2 phi3 is parity-odd; so no
#          parity-even one-loop (Coleman--Weinberg) source generates it.
#          [Prop. 7.7]
#
#  What is only STRUCTURALLY checked (Section B), with an explicit caveat:
#    (v)   The so(3,3) adjoint quartic Tr(ad_Phi^4) contains a NONZERO
#          (Tr Phi^2)^2 piece -- confirming that the gauge sector DOES supply
#          the (Tr Phi^2)^2 invariant that the fermion sector lacks
#          [the qualitative content of Prop. 7.6(2)].
#    CAVEAT.  The generic adjoint gives  Tr(ad_Phi^4) = 4 Tr Phi^4
#             + (3/2)(Tr Phi^2)^2, i.e. ratio (Tr Phi^2)^2 : Tr Phi^4 = 3:8,
#             and Tr(Phi^3 I) = -48 phi1 phi2 phi3 in this normalization.
#             These do NOT reproduce the monograph's quoted integers
#             [ sum m_a^4 = 1024 Tr Phi^4 + 3072 (Tr Phi^2)^2  (ratio 3:1) ]
#             nor the quoted cubic coefficient (-6).  Those numbers depend on
#             the specific gauge-boson mass prescription / generator and
#             coupling normalization fixed elsewhere in the monograph and are
#             NOT asserted by this script.  Section B asserts only the
#             normalization-independent structural fact (presence of both
#             invariants).
#
#  Dependencies: sympy.   Run: python3 verify_prop_7_6_radiative_quartics.py
# =============================================================================
import sympy as sp
from sympy import eye, zeros, symbols, expand, kronecker_product as kp
from itertools import product, combinations
import sys

I2 = eye(2)
s1 = sp.Matrix([[0, 1], [1, 0]]); s3 = sp.Matrix([[1, 0], [0, -1]]); ep = sp.Matrix([[0, 1], [-1, 0]])
def kron(*M):
    o = M[0]
    for m in M[1:]:
        o = kp(o, m)
    return sp.Matrix(o)

e = {1: kron(s1, I2, I2), 2: kron(s3, s1, I2), 3: kron(s3, s3, s1),
     4: kron(ep, I2, I2), 5: kron(s3, ep, I2), 6: kron(s3, s3, ep)}
Ip = e[1] * e[2] * e[3] * e[4] * e[5] * e[6]
om = {i: e[i] * e[i + 3] for i in (1, 2, 3)}          # boost-Cartan omega^i

f1, f2, f3 = symbols('phi1 phi2 phi3', real=True)
Phi = f1 * om[1] + f2 * om[2] + f3 * om[3]            # Def. 7.4 condensate

P4 = f1**4 + f2**4 + f3**4
PP = f1**2 * f2**2 + f1**2 * f3**2 + f2**2 * f3**2

def in_basis(expr):
    """Write a symmetric quartic as A*P4 + B*PP and return (A, B)."""
    A, B = symbols('A B')
    sol = sp.solve(sp.Poly(expand(expr - (A * P4 + B * PP)), f1, f2, f3).coeffs(),
                   [A, B], dict=True)
    return (sol[0][A], sol[0][B]) if sol else None

checks = []
def check(name, cond):
    checks.append(bool(cond)); print(f"  [{'OK' if cond else 'FAIL'}] {name}")

# ============================ SECTION A (EXACT) =============================
print("=== Section A : exact octant / trace identities ===")
TrP2  = expand((Phi**2).trace())
TrP4  = expand((Phi**4).trace())
TrP3I = expand((Phi**3 * Ip).trace())

def octsum(n):
    return expand(sum((e0 * f1 + e1 * f2 + e2 * f3)**n
                      for e0, e1, e2 in product((1, -1), repeat=3)))
S2, S4 = octsum(2), octsum(4)

check("Tr Phi^2 = sum_eps (eps.phi)^2",            expand(TrP2 - S2) == 0)
check("Tr Phi^4 = sum_eps (eps.phi)^4",            expand(TrP4 - S4) == 0)
check("Tr Phi^2 = 8 sum phi_i^2",                  expand(TrP2 - 8 * (f1**2 + f2**2 + f3**2)) == 0)
check("Tr Phi^4 = 8 sum phi^4 + 48 sum phi^2phi^2", expand(TrP4 - (8 * P4 + 48 * PP)) == 0)

aB = in_basis(TrP4); aC = in_basis(expand(TrP2**2))
print(f"      Tr Phi^4      = {aB[0]}*P4 + {aB[1]}*PP")
print(f"      (Tr Phi^2)^2  = {aC[0]}*P4 + {aC[1]}*PP")
det = sp.Matrix([[aB[0], aB[1]], [aC[0], aC[1]]]).det()
print(f"      coefficient determinant = {det}")
check("Tr Phi^4, (Tr Phi^2)^2 independent (det != 0)", det != 0)
check("  => fermion octant loop generates B, contributes 0 to C", det != 0)

# parity (Prop. 7.7)
print("Parity (Prop. 7.7):")
check("octant quartic even under phi1 -> -phi1", expand(S4.subs(f1, -f1) - S4) == 0)
check("chiral cubic phi1 phi2 phi3 is parity-odd",
      expand((f1 * f2 * f3).subs(f1, -f1) + f1 * f2 * f3) == 0)
check("Tr(Phi^3 I) is proportional to phi1 phi2 phi3",
      sp.simplify(TrP3I / (f1 * f2 * f3)).free_symbols == set())
print(f"      Tr(Phi^3 I) = {TrP3I}   (parity-odd; coefficient is normalization-dependent)")

# ===================== SECTION B (STRUCTURAL, caveated) ====================
print("\n=== Section B : gauge sector (structural; coefficients NOT asserted) ===")
biv = [e[a] * e[b] for a, b in combinations(range(1, 7), 2)]   # 15 so(3,3) generators
n = len(biv)
Gm = sp.Matrix(n, n, lambda i, j: (biv[i].T * biv[j]).trace())
Ginv = Gm.inv()
def decomp(M):
    return Ginv * sp.Matrix([(biv[i].T * M).trace() for i in range(n)])
A = sp.Matrix.hstack(*[decomp(expand(Phi * biv[k] - biv[k] * Phi)) for k in range(n)])
TrA4 = expand((A * A * A * A).trace())
coeff = in_basis(TrA4)
x, y = symbols('x y')
sol = sp.solve(sp.Poly(expand(TrA4 - (x * TrP4 + y * expand(TrP2**2))), f1, f2, f3).coeffs(),
               [x, y], dict=True)[0]
print(f"      Tr(ad_Phi^4) = {sol[x]} * Tr Phi^4 + {sol[y]} * (Tr Phi^2)^2")
print(f"      generic adjoint ratio (Tr Phi^2)^2 : Tr Phi^4 = {sp.nsimplify(sol[y] / sol[x])}"
      f"   (monograph quotes 3:1 -- requires its specific gauge-mass normalization)")
check("gauge adjoint generates a NONZERO (Tr Phi^2)^2 invariant", sol[y] != 0)
check("  => gauge sector supplies C (fermion sector cannot)", sol[y] != 0)

# ---- summary ---------------------------------------------------------------
n_ok = sum(checks)
print(f"\n{n_ok}/{len(checks)} checks passed.")
sys.exit(0 if n_ok == len(checks) else 1)