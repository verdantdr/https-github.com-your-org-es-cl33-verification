\@writefile{lof}{\contentsline {figure}{\numberline {G.2}{\ignorespaces The mass-shell $p_W^2-\mathbf  p^2=(m_{\mathrm  {ext}}c)^2$ in energy--momentum form (intercept $mc^2$) against its Newtonian limit $E\approx mc^2+p^2/2m$. The two agree at small momentum and diverge as $\beta =v/c\to 1$. Inset: the fractional error of the Newtonian kinetic energy, growing as $\beta ^2/4$ (Proposition~\ref {prop:sr-correction}).}}{64}{figure.G.2}\protected@file@percent }
\newlabel{fig:massshell-sr}{{G.2}{64}{The mass-shell $p_W^2-\mathbf p^2=(m_{\mathrm {ext}}c)^2$ in energy--momentum form (intercept $mc^2$) against its Newtonian limit $E\approx mc^2+p^2/2m$. The two agree at small momentum and diverge as $\beta =v/c\to 1$. Inset: the fractional error of the Newtonian kinetic energy, growing as $\beta ^2/4$ (Proposition~\ref {prop:sr-correction})}{figure.G.2}{}}
