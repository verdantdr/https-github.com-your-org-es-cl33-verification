\@writefile{lof}{\contentsline {figure}{\numberline {G.1}{\ignorespaces The momentum--force--energy tower of the negative pole. A single first-order operator $\alpha =\partial _\lambda +G$ and its dual $\alpha ^*$ generate momentum, force and energy at derivative orders $1,2,3$ (Proposition~\ref {prop:tower-classical}). When the force rung vanishes, $F=\alpha ^*\alpha X=0$, the momentum $p=\alpha X$ is conserved -- the law of inertia (Section~\ref {sec:newton-first}).}}{63}{figure.G.1}\protected@file@percent }
\newlabel{fig:tower}{{G.1}{63}{The momentum--force--energy tower of the negative pole. A single first-order operator $\alpha =\partial _\lambda +G$ and its dual $\alpha ^*$ generate momentum, force and energy at derivative orders $1,2,3$ (Proposition~\ref {prop:tower-classical}). When the force rung vanishes, $F=\alpha ^*\alpha X=0$, the momentum $p=\alpha X$ is conserved -- the law of inertia (Section~\ref {sec:newton-first})}{figure.G.1}{}}
\newlabel{prop:tower-classical}{{G.1}{63}{The chain is a derivative-order tower}{theorem.G.1}{}}
