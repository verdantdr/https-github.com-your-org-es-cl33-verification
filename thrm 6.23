#!/usr/bin/env python3
# =============================================================================
#  verify_thm_6_23_vacuum_mirror.py
#
#  Electromagnetic Sphere monograph -- machine verification of
#     Prop. 6.22  (prop:sea-spectrum)  -- the balanced energy spectrum
#     Prop. 6.23  (prop:sea-mirror)    -- the vacuum is the chiral mirror of
#                                         matter; STABILITY of the negative-mass
#                                         branch (no tachyon).
#
#  Status of the verified statements:
#     [EXACT]   the algebraic identities (Clifford relations, H^2, mirror)
#     [DERIVED] the stability conclusion (isospectral +/-m branches, omega^2>=0)
#
#  Strategy.  We build the explicit 8x8 REAL representation of Cl(3,3) used
#  throughout Part I, with e1,e2,e3 squaring to +1 (temporal) and e4,e5,e6 to
#  -1 (spatial), via Kronecker products of the real 2x2 matrices
#       s1=[[0,1],[1,0]]  (symmetric, +I),
#       s3=[[1,0],[0,-1]] (symmetric, +I),
#       ep=[[0,1],[-1,0]] (antisymmetric, -I).
#  Everything else (W-hat clock, Dirac matrices G_a, covariant-mass trivector V,
#  pseudoscalar I, single-particle Hamiltonian H) is derived from these and the
#  six monograph claims are checked symbolically; the spectrum is confirmed
#  numerically.
#
#  Dependencies:  sympy, numpy.   Run:  python3 verify_thm_6_23_vacuum_mirror.py
#  Expected: every check prints OK and the script exits 0.
# =============================================================================
import sympy as sp
from sympy import sqrt, eye, zeros, symbols, simplify, kronecker_product as kp
import numpy as np

# ---- real 2x2 seeds --------------------------------------------------------
I2 = eye(2)
s1 = sp.Matrix([[0, 1], [1, 0]])     # symmetric,  s1^2 = +I
s3 = sp.Matrix([[1, 0], [0, -1]])    # symmetric,  s3^2 = +I
ep = sp.Matrix([[0, 1], [-1, 0]])    # antisymmetric, ep^2 = -I

def kron(*mats):
    out = mats[0]
    for m in mats[1:]:
        out = kp(out, m)
    return sp.Matrix(out)

I8, Z8 = eye(8), zeros(8, 8)
ac = lambda A, B: A * B + B * A      # anticommutator
co = lambda A, B: A * B - B * A      # commutator

# ---- Cl(3,3) generators in the 8x8 real representation ---------------------
e = {
    1: kron(s1, I2, I2), 2: kron(s3, s1, I2), 3: kron(s3, s3, s1),   # e_i^2 = +I
    4: kron(ep, I2, I2), 5: kron(s3, ep, I2), 6: kron(s3, s3, ep),   # e_i^2 = -I
}
eta = {1: 1, 2: 1, 3: 1, 4: -1, 5: -1, 6: -1}

checks = []
def check(name, cond):
    checks.append((name, bool(cond)))
    print(f"  [{'OK' if cond else 'FAIL'}] {name}")

print("Cl(3,3) defining relations  {e_M,e_N} = 2 eta_MN :")
clifford_ok = all(
    simplify(ac(e[a], e[b]) - (2 * eta[a] * I8 if a == b else Z8)) == Z8
    for a in range(1, 7) for b in range(1, 7)
)
check("Clifford anticommutators (signature (3,3))", clifford_ok)

# ---- derived objects -------------------------------------------------------
W  = (e[1] + e[2] + e[3]) / sqrt(3)                  # kernel clock W-hat
G  = {a: simplify(W * e[3 + a]) for a in (1, 2, 3)}  # interior Dirac matrices
V  = simplify(e[4] * e[5] * e[6])                    # covariant-mass trivector
Ip = simplify(e[1] * e[2] * e[3] * e[4] * e[5] * e[6])  # pseudoscalar I

print("\nClock, Dirac matrices, mass trivector, pseudoscalar :")
check("W-hat^2 = I",                       simplify(W * W - I8) == Z8)
for a in (1, 2, 3):
    check(f"G{a} symmetric",               simplify(G[a].T - G[a]) == Z8)
    check(f"G{a}^2 = +I",                  simplify(G[a] * G[a] - I8) == Z8)
check("{G1,G2}={G1,G3}={G2,G3}=0",
      all(simplify(ac(G[i], G[j])) == Z8 for i, j in [(1, 2), (1, 3), (2, 3)]))
for a in (1, 2, 3):
    check(f"{{V,G{a}}} = 0  (covariant mass)", simplify(ac(V, G[a])) == Z8)
check("I^2 = +I",                          simplify(Ip * Ip - I8) == Z8)
check("[I,G_a] = 0  (chiral kinetic)",
      all(simplify(co(Ip, G[a])) == Z8 for a in (1, 2, 3)))
check("{I,V} = 0  (chiral mass)",          simplify(ac(Ip, V)) == Z8)

# ---- Prop. 6.22 : H traceless, H^2 = (p^2+m^2) I ---------------------------
p1, p2, p3, m = symbols('p1 p2 p3 m', real=True)
H  = lambda mm: p1 * G[1] + p2 * G[2] + p3 * G[3] + mm * V
Hm = H(m)
print("\nProp. 6.22  (balanced spectrum) :")
check("Tr H = 0",                          simplify(Hm.trace()) == 0)
check("H^2 = (p1^2+p2^2+p3^2+m^2) I",
      simplify(Hm * Hm - (p1**2 + p2**2 + p3**2 + m**2) * I8) == Z8)

# ---- Prop. 6.23 : the chiral mirror  I H(m) I = H(-m) ----------------------
print("\nProp. 6.23  (vacuum is the chiral mirror; stability) :")
check("I H(m) I = H(-m)  (mirror identity)",
      simplify(Ip * Hm * Ip - H(-m)) == Z8)

# spectrum + isospectrality + no-tachyon (numeric, exact rational momenta)
subs = {p1: sp.Rational(2), p2: sp.Rational(-1), p3: sp.Rational(3), m: sp.Rational(5, 2)}
omega2 = float((p1**2 + p2**2 + p3**2 + m**2).subs(subs))     # = 20.25
Hp = np.array(H(m).subs(subs)).astype(float)
Hn = np.array(H(-m).subs(subs)).astype(float)
wp = np.round(np.sort(np.linalg.eigvalsh(Hp)), 9)
wn = np.round(np.sort(np.linalg.eigvalsh(Hn)), 9)
want = np.array([-omega2**0.5] * 4 + [omega2**0.5] * 4)
check("spec H(+m) = {+/-sqrt(p^2+m^2)}, 4+4 degenerate",
      np.allclose(wp, np.round(want, 9)))
check("isospectral: spec H(m) = spec H(-m)", np.allclose(wp, wn))
check("dispersion omega^2 = p^2+m^2 > 0  =>  NO tachyon", omega2 > 0)

# ---- antipodal V on the octant (boost-Cartan) basis ------------------------
print("\nAntipodal mass pairing on the octants :")
om = {k: simplify(e[k] * e[k + 3]) for k in (1, 2, 3)}        # omega^k = e_k e_{k+3}
check("[omega_i, omega_j] = 0  (simultaneous octant basis)",
      all(simplify(co(om[i], om[j])) == Z8 for i in (1, 2, 3) for j in (1, 2, 3)))
check("{V, omega^k} = 0  =>  V maps each octant to its antipode",
      all(simplify(ac(V, om[k])) == Z8 for k in (1, 2, 3)))

# ---- summary ---------------------------------------------------------------
n_ok = sum(v for _, v in checks)
print(f"\n{n_ok}/{len(checks)} checks passed.")
import sys
sys.exit(0 if n_ok == len(checks) else 1)