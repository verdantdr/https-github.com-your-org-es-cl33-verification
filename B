#!/usr/bin/env wolframscript
(* ::Package:: *)

(* ==================================================================== *
 *  es_cl33_verification.wl
 *  --------------------------------------------------------------------
 *  Machine-verified derivations for
 *
 *      "The Electromagnetic Sphere:
 *       A Geometric Unification on the Split-Signature
 *       Clifford Algebra Cl(3,3)"  --  Part I
 *      (B. Driss)
 *
 *  This single script reproduces EVERY row of Appendix B, Table B.1
 *  ("Summary of verified identities"), index 1 through 17.  Each
 *  section is named for the identity it establishes and is anchored
 *  to an explicit, literal Wolfram Language output.
 *
 *  Conventions (Appendix B, "The representation"):
 *      sx, sz                 real Pauli matrices
 *      eps = ((0,-1),(1,0))   real antisymmetric unit
 *      e1 = sx (x) 1 (x) 1     e4 = eps (x) 1  (x) 1
 *      e2 = sz (x) sx (x) 1    e5 = sz (x) eps (x) 1
 *      e3 = sz (x) sz (x) sx   e6 = sz (x) sz (x) eps
 *      {e_i,e_j} = 2 eta_ij 1 ,  eta = diag(+,+,+,-,-,-)
 *      Wh  = (e1+e2+e3)/Sqrt3                 (kernel / clock)
 *      J   = (e2 e3 + e3 e1 + e1 e2)/Sqrt3    (photon)
 *      G_a = Wh e_{3+a}                       (boosts / Dirac space part)
 *      V   = e4 e5 e6                         (mass trivector)
 *      g0  = Wh ,  g^k = e_{3+k}              (Dirac gammas)
 *      I6  = e1 e2 e3 e4 e5 e6                (pseudoscalar)
 *
 *  Run:    wolframscript -file es_cl33_verification.wl
 *  or paste into a Wolfram notebook (Shift+Enter).
 *  No external packages.  All verdicts use exact symbolic / rational
 *  arithmetic -- no floating point enters any PASS/FAIL decision.
 * ==================================================================== *)

ClearAll["Global`*"];

(* ----------------------------- harness ----------------------------- *)
report = {};
banner[s_] := (Print[]; Print[StringRepeat["=", 72]];
               Print["  ", s]; Print[StringRepeat["=", 72]]);
emit[row_, supports_, claim_, passQ_, literal_] := Module[{v},
  v = If[TrueQ[passQ], "PASS", "FAIL"];
  AppendTo[report, {row, claim, supports, v}];
  Print[]; Print["[Row ", row, "]  ", claim];
  Print["    supports : ", supports];
  Print["    literal  : ", literal];
  Print["    verdict  : ", v];
];

(* =================================================================== *)
banner["0.  Real 8x8 representation of Cl(3,3)  (Jordan-Wigner)"];
(* =================================================================== *)
sx   = {{0, 1}, {1, 0}};
sz   = {{1, 0}, {0, -1}};
eps  = {{0, -1}, {1, 0}};
id2  = IdentityMatrix[2];
id8  = IdentityMatrix[8];
KP[a_, b_, c_] := KroneckerProduct[KroneckerProduct[a, b], c];

e[1] = KP[sx, id2, id2];  e[2] = KP[sz, sx, id2];  e[3] = KP[sz, sz, sx];
e[4] = KP[eps, id2, id2]; e[5] = KP[sz, eps, id2]; e[6] = KP[sz, sz, eps];

eta = DiagonalMatrix[{1, 1, 1, -1, -1, -1}];
comm[a_, b_] := a.b - b.a;
anti[a_, b_] := a.b + b.a;

(* derived geometric objects *)
Wh  = (e[1] + e[2] + e[3])/Sqrt[3];                       (* kernel / clock   *)
Jph = (e[2].e[3] + e[3].e[1] + e[1].e[2])/Sqrt[3];        (* photon           *)
Lt[1] = e[2].e[3]; Lt[2] = e[3].e[1]; Lt[3] = e[1].e[2];  (* su(2)_T          *)
Js[1] = e[5].e[6]; Js[2] = e[6].e[4]; Js[3] = e[4].e[5];  (* su(2)_S          *)
G[1]  = Wh.e[4];   G[2]  = Wh.e[5];   G[3]  = Wh.e[6];     (* boosts           *)
Vol   = e[4].e[5].e[6];                                    (* mass trivector   *)
gam[0] = Wh; gam[1] = e[4]; gam[2] = e[5]; gam[3] = e[6];  (* Dirac gammas     *)
Ps    = e[1].e[2].e[3].e[4].e[5].e[6];                     (* pseudoscalar I   *)
Print["representation built:  e[1..6], Wh, Jph, G[1..3], Vol, gam[0..3], Ps"];

(* =================================================================== *)
banner["Identities 1-17  (Table B.1)"];
(* =================================================================== *)

(* --- Row 1 :  Clifford relations ----------------------------------- *)
row1 = And @@ Flatten @ Table[anti[e[i], e[j]] == 2 eta[[i, j]] id8, {i, 6}, {j, 6}];
emit[1, "Prop. 2.1 (rep)",
  "{e_i,e_j} = 2 eta_ij I  for all 36 ordered pairs",
  row1, "all 36 anticommutators equal 2 eta_ij I  ->  " <> ToString[row1]];

(* --- Row 2 :  kernel squares to +1 --------------------------------- *)
row2 = TrueQ[Simplify[Wh.Wh == id8]];
emit[2, "Prop. 2.7 (frame)", "Wh^2 = +I",
  row2, "Wh.Wh - I  ->  " <> ToString[Simplify[Wh.Wh - id8] // Normal // Total // Total]];

(* --- Row 3 :  photon squares to -1 --------------------------------- *)
row3 = TrueQ[Simplify[Jph.Jph == -id8]];
emit[3, "Prop. 4.x (photon)", "J^2 = -I  (J acts as a complex structure)",
  row3, "J.J + I  ->  zero matrix : " <> ToString[row3]];

(* --- Row 4 :  Killing norm of the photon --------------------------- *)
trJ2 = Simplify[Tr[Jph.Jph]];
row4 = (trJ2 === -8);
emit[4, "Prop. 2.10 (census)", "Tr(J^2) = -8  (compact / healthy Killing sign)",
  row4, "Tr(J^2) = " <> ToString[trJ2]];

(* --- Row 5 :  photon commutes with the clock ----------------------- *)
row5 = TrueQ[Simplify[comm[Jph, Wh] == 0 id8]];
emit[5, "Prop. 4.x (photon)", "[J, Wh] = 0",
  row5, "[J,Wh] = zero matrix : " <> ToString[row5]];

(* --- Row 6 :  the centralizer of the clock is one-dimensional ------ *)
(* su(2)_T closes with structure constant -2 *)
su2T = And[comm[Lt[1], Lt[2]] == -2 Lt[3],
           comm[Lt[2], Lt[3]] == -2 Lt[1],
           comm[Lt[3], Lt[1]] == -2 Lt[2]];
clock = e[1] + e[2] + e[3];
Xgen  = a Lt[1] + b Lt[2] + c Lt[3];
centSol = Solve[Thread[Flatten[comm[Xgen, clock]] == 0], {a, b, c}];
democSq = Simplify[(Lt[1] + Lt[2] + Lt[3]).(Lt[1] + Lt[2] + Lt[3])]; (* = -3 I *)
row6 = (su2T === True) && (centSol === {{b -> a, c -> a}});
emit[6, "Prop. 4.2 (photon)",
  "centralizer of Wh in su(2)_T is 1-dimensional, spanned by J",
  row6,
  "su(2)_T struct.const = -2 : " <> ToString[su2T] <>
  " ;  Solve[[X,clock]=0] = " <> ToString[centSol] <>
  " ;  (L1+L2+L3)^2 = -3 I"];

(* --- Row 7 :  boost squares / anticommutators ---------------------- *)
row7a = And @@ Table[G[k].G[k] == id8, {k, 3}];
row7b = And @@ Flatten @ Table[If[k != l, anti[G[k], G[l]] == 0 id8, Nothing], {k, 3}, {l, 3}];
row7 = row7a && row7b;
emit[7, "Thm. 9.x (no-ghost)",
  "G_a^2 = +I  and  {G_a,G_b} = 0  (a != b)",
  row7, "squares +I : " <> ToString[row7a] <> " ;  cross-anticommutators 0 : " <> ToString[row7b]];

(* --- Row 8 :  boost curvature is rotational (spin) ----------------- *)
row8 = And[comm[G[1], G[2]] == -2 Js[3],
           comm[G[2], G[3]] == -2 Js[1],
           comm[G[3], G[1]] == -2 Js[2]];
emit[8, "Prop. 6.x (spin-curvature)",
  "[G_X,G_Y] = -2 e4e5 = -2 J3  (and cyclic)  ->  spin 1/2 holonomy",
  row8, "[G_X,G_Y]+2 J3 = 0 (and cyclic) : " <> ToString[row8]];

(* --- Row 9 :  mass trivector properties ---------------------------- *)
row9a = TrueQ[Simplify[Vol.Vol == id8]];
row9b = And @@ Table[anti[G[k], Vol] == 0 id8, {k, 3}];
row9c = TrueQ[Simplify[Transpose[Vol] == Vol]];
row9 = row9a && row9b && row9c;
emit[9, "Thm. 7.x (mass-space)",
  "V^2 = +I ,  {G_a,V} = 0 ,  V^T = V",
  row9, "V^2=I : " <> ToString[row9a] <> " ;  {G_a,V}=0 : " <> ToString[row9b] <>
        " ;  V symmetric : " <> ToString[row9c]];

(* --- Row 10 :  Hamiltonian is real-symmetric ----------------------- *)
Hm = G[1] p1 + G[2] p2 + G[3] p3 + m Vol;
row10 = TrueQ[Simplify[Transpose[Hm] == Hm]];
emit[10, "Thm. 9.x (no-ghost)",
  "H = G1 p1 + G2 p2 + G3 p3 + m V  is real symmetric  (no ghost)",
  row10, "H^T - H = zero matrix : " <> ToString[row10]];

(* --- Row 11 :  relativistic dispersion ----------------------------- *)
H2 = Simplify[Hm.Hm];
row11 = TrueQ[Simplify[H2 == (p1^2 + p2^2 + p3^2 + m^2) id8]];
emit[11, "Thm. 9.x (no-ghost)",
  "H^2 = (p^2 + m^2) I  =>  spec(H) = +/- Sqrt(p^2+m^2)",
  row11, "H^2 = (p1^2+p2^2+p3^2+m^2) I : " <> ToString[row11]];

(* --- Row 12 :  Dirac algebra of the (1,3) block -------------------- *)
mink = DiagonalMatrix[{1, -1, -1, -1}];
row12 = And @@ Flatten @ Table[
   anti[gam[mu], gam[nu]] == 2 mink[[mu + 1, nu + 1]] id8, {mu, 0, 3}, {nu, 0, 3}];
emit[12, "Prop. 6.x (dirac-matrices)",
  "{g^mu,g^nu} = 2 diag(+,-,-,-) I   (Lorentzian signature is read off)",
  row12, "all 16 anticommutators match 2 eta^{mu nu} I : " <> ToString[row12]];

(* --- Row 13 :  energy pairing of the clock ------------------------- *)
trg0  = Simplify[Tr[gam[0]]];
specg0 = Sort[Eigenvalues[gam[0]]];
row13 = (trg0 === 0) && (specg0 === {-1, -1, -1, -1, 1, 1, 1, 1});
emit[13, "Prop. 9.x (4+4)",
  "Tr(g^0) = 0 ,  spec(g^0) = {(+1)^4,(-1)^4}  (4 particle + 4 antiparticle)",
  row13, "Tr(g^0) = " <> ToString[trg0] <> " ;  spec(g^0) = " <> ToString[specg0]];

(* --- Row 14 :  charge quantization --------------------------------- *)
specJ = Sort[Eigenvalues[Jph]];
specQ = Sort[Eigenvalues[Simplify[-I Jph]]];           (* Q = -i J *)
row14 = (specJ === {-I, -I, -I, -I, I, I, I, I}) &&
        (specQ === {-1, -1, -1, -1, 1, 1, 1, 1});
emit[14, "Prop. 5.x (couplings)",
  "spec(J) = {(+i)^4,(-i)^4}  =>  Q=-iJ has eigenvalues +/-1  =>  q = +/- 1/2",
  row14, "spec(J) = " <> ToString[specJ] <> " ;  spec(Q=-iJ) = " <> ToString[specQ]];

(* =================================================================== *)
banner["Row 15 : gravitational double-contraction (symbolic, n = 4 and 6)"];
(* =================================================================== *)
(* delta^{apq}_{drs} R^{rs}_{pq} = -4 R^a_d + 2 delta^a_d R = -4 G^a_d *)
gravCheck[n_] := Module[
  {kd, gk, seed, P1, P2, P3, Alt, Rp0, Rp, RR, Tc, Ric, Rs, sol, verdict},
  kd[i_, j_] := KroneckerDelta[i, j];
  gk[a_, p_, q_, d_, r_, s_] := Det[{
     {kd[a, d], kd[a, r], kd[a, s]},
     {kd[p, d], kd[p, r], kd[p, s]},
     {kd[q, d], kd[q, r], kd[q, s]}}];
  seed = Array[r0, {n, n, n, n}];
  (* project a generic seed onto the algebraic-curvature subspace *)
  P1[t_] := Table[(t[[a, b, c, d]] - t[[b, a, c, d]])/2, {a, n}, {b, n}, {c, n}, {d, n}];
  P2[t_] := Table[(t[[a, b, c, d]] - t[[a, b, d, c]])/2, {a, n}, {b, n}, {c, n}, {d, n}];
  P3[t_] := Table[(t[[a, b, c, d]] + t[[c, d, a, b]])/2, {a, n}, {b, n}, {c, n}, {d, n}];
  Alt[t_] := Table[(1/3)(t[[a, b, c, d]] + t[[a, c, d, b]] + t[[a, d, b, c]]),
                   {a, n}, {b, n}, {c, n}, {d, n}];           (* removes 1st-Bianchi violation *)
  Rp0 = P3[P2[P1[seed]]]; Rp = Rp0 - Alt[Rp0];
  RR[a_, b_, c_, d_] := Rp[[a, b, c, d]];
  Tc[a_, d_]  := Sum[gk[a, p, q, d, r, s] RR[r, s, p, q], {p, n}, {q, n}, {r, n}, {s, n}];
  Ric[a_, d_] := Sum[RR[b, a, b, d], {b, n}];                 (* Ric_ad = R^b_abd *)
  Rs = Sum[Ric[a, a], {a, n}];
  sol = Solve[Thread[
     DeleteCases[Expand[Flatten @ Table[
        Tc[a, d] - (al Ric[a, d] + be kd[a, d] Rs), {a, n}, {d, n}]], 0] == 0], {al, be}];
  verdict = And @@ (# === 0 & /@ Flatten @ Table[
     Expand[Tc[a, d] - (-4 Ric[a, d] + 2 kd[a, d] Rs)], {a, n}, {d, n}]);
  {sol, verdict}];

{sol4, v4} = gravCheck[4];
{sol6, v6} = gravCheck[6];
row15 = (sol4 === {{al -> -4, be -> 2}}) && TrueQ[v4] &&
        (sol6 === {{al -> -4, be -> 2}}) && TrueQ[v6];
emit[15, "Thm. 5.x (split contraction)",
  "delta^{apq}_{drs} R^{rs}_{pq} = -4 R^a_d + 2 delta^a_d R = -4 G^a_d   (n = 4 and 6)",
  row15,
  "n=4 fit (alpha,beta) = " <> ToString[sol4] <> " , identity " <> ToString[v4] <>
  " ;  n=6 fit (alpha,beta) = " <> ToString[sol6] <> " , identity " <> ToString[v6]];

(* =================================================================== *)
banner["Rows 16-17 : surplus-time constraint algebra on T*M^6 (symbolic)"];
(* =================================================================== *)
dim = 6;
xc = Array[xx, dim]; pc = Array[PP, dim];
pb[f_, h_] := Sum[D[f, xc[[L]]] D[h, pc[[L]]] - D[f, pc[[L]]] D[h, xc[[L]]], {L, dim}];

(* Row 17 : master identity, fully generic symmetric inverse metric and vector field *)
gm = Table[gg[Min[i, j], Max[i, j]] @@ xc, {i, dim}, {j, dim}];     (* g^{NK}(x), symmetric *)
uv = Table[uu[i] @@ xc, {i, dim}];                                  (* u^M(x)              *)
Cc  = Sum[gm[[en, k]] pc[[en]] pc[[k]], {en, dim}, {k, dim}];       (* unnormalized C = g P P *)
phi = Sum[uv[[mm]] pc[[mm]], {mm, dim}];                            (* phi = u^M P_M       *)
Lieg = Table[Sum[
    uv[[L]] D[gm[[en, k]], xc[[L]]]
    - gm[[L, k]] D[uv[[en]], xc[[L]]]
    - gm[[en, L]] D[uv[[k]], xc[[L]]], {L, dim}], {en, dim}, {k, dim}];
RHS17 = -Sum[Lieg[[en, k]] pc[[en]] pc[[k]], {en, dim}, {k, dim}];
row17 = (Simplify[pb[phi, Cc] - RHS17] === 0);

(* Row 16 : two surplus constraints with constant (Killing) directions commute *)
u1 = {1/Sqrt[2], -1/Sqrt[2], 0, 0, 0, 0};            (* (e1-e2)/Sqrt2 *)
u2 = {1/Sqrt[6], 1/Sqrt[6], -2/Sqrt[6], 0, 0, 0};    (* (e1+e2-2e3)/Sqrt6 *)
row16 = (Simplify[pb[u1.pc, u2.pc]] === 0);

(* Boundary witnesses for the iff-Killing statement *)
gFail = DiagonalMatrix[{1 + xx[5]^2, 1, 1, 1, 1, 1}];           (* g^{tt} carries surplus dep *)
CFail = Sum[gFail[[en, k]] pc[[en]] pc[[k]], {en, dim}, {k, dim}];
brkFail = Simplify[pb[UnitVector[dim, 5].pc, CFail]];          (* expect -2 x5 p1^2 != 0 *)
gOK = DiagonalMatrix[{1 + xx[4]^2, 1, 1, 1, 1, 1}];            (* depends on interior x4 only *)
COK = Sum[gOK[[en, k]] pc[[en]] pc[[k]], {en, dim}, {k, dim}];
brkOK = Simplify[pb[UnitVector[dim, 5].pc, COK]];             (* expect 0 *)

emit[16, "Prop. 9.x (first-class)",
  "{phi1,phi2} = 0  (flat surplus plane: surplus translations commute)",
  row16, "{phi1,phi2} = " <> ToString[Simplify[pb[u1.pc, u2.pc]]]];

emit[17, "Thm. 10.x (master identity)",
  "{phi_a,C} = -(Lie_{u_a} g^{NK}) P_N P_K ;  = 0  <=>  Lie_{u_a} g = 0 (Killing)",
  row17,
  "generic identity {phi,C}+ (Lie_u g)PP = 0 : " <> ToString[row17] <>
  " ;  Killing FAILS: {d5,C[g^11=1+x5^2]} = " <> ToString[brkFail] <>
  " ;  Killing HOLDS: {d5,C[g^11=1+x4^2]} = " <> ToString[brkOK]];

(* =================================================================== *)
banner["SUMMARY  (all rows of Table B.1)"];
(* =================================================================== *)
Print[Grid[Prepend[report, {"#", "Identity", "Supports", "Verdict"}],
           Frame -> All, Alignment -> Left]];
Print[];
Print["Rows PASS : ", Count[report[[All, 4]], "PASS"], " / ", Length[report]];
If[FreeQ[report[[All, 4]], "FAIL"],
   Print["ALL IDENTITIES VERIFIED."],
   Print["FAILURES PRESENT -- inspect rows marked FAIL."]];
